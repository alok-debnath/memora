{
  "name": "memora",
  "version": "1.0.0",
  "private": true,
  "packageManager": "bun@1.3.14",
  "main": "index.js",
  "scripts": {
    "start": "APP_VARIANT=development expo start",
    "start:dev-client": "APP_VARIANT=development expo start --dev-client",
    "prebuild": "expo prebuild",
    "prebuild:dev": "APP_VARIANT=development expo prebuild",
    "web": "APP_VARIANT=development expo start --web",
    "android": "APP_VARIANT=development NODE_OPTIONS=--max-old-space-size=8192 expo run:android --device",
    "ios": "APP_VARIANT=development expo run:ios",
    "build": "expo export",
    "build:apk": "export $(grep -v '^#' .env.local | xargs) && APP_VARIANT=production eas build --platform android --profile preview-apk --local",
    "build:aab": "export $(grep -v '^#' .env.local | xargs) && APP_VARIANT=production eas build --platform android --profile preview-aab --local",
    "prepare": "lefthook install",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "ui:check": "bun scripts/check-ui-consistency.ts",
    "check": "bun run ui:check && bun run typecheck && bun test && bun run test:convex",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bun test",
    "test:convex": "vitest run"
  },
  "dependencies": {
    "@believer/react-native-markdown-display": "^8.4.1",
    "@better-auth/expo": "1.6.23",
    "@convex-dev/better-auth": "^0.12.5",
    "@convex-dev/migrations": "^0.3.5",
    "@expo-google-fonts/dm-sans": "^0.4.2",
    "@expo-google-fonts/space-grotesk": "^0.4.1",
    "@expo/ui": "~57.0.7",
    "@gorhom/bottom-sheet": "^5.2.14",
    "@react-native-async-storage/async-storage": "3.1.1",
    "@react-native-clipboard/clipboard": "^1.16.3",
    "@react-native-community/netinfo": "12.0.1",
    "@react-native-vector-icons/feather": "^13.1.2",
    "@react-native-vector-icons/fontawesome5": "^13.1.2",
    "@shopify/flash-list": "2.3.2",
    "@siteed/audio-studio": "^3.2.1",
    "@stardazed/streams-text-encoding": "^1.0.2",
    "@tamagui/animations-react-native": "2.5.0",
    "@tamagui/config": "2.5.0",
    "@tamagui/native": "2.5.0",
    "@ungap/structured-clone": "^1.3.3",
    "@vvo/tzdb": "^6.198.0",
    "better-auth": "1.6.23",
    "convex": "^1.42.3",
    "dayjs": "^1.11.21",
    "expo": "~57.0.7",
    "expo-asset": "~57.0.6",
    "expo-audio": "~57.0.2",
    "expo-auth-session": "~57.0.4",
    "expo-blur": "~57.0.2",
    "expo-clipboard": "~57.0.1",
    "expo-constants": "~57.0.6",
    "expo-crypto": "~57.0.1",
    "expo-dev-client": "~57.0.7",
    "expo-document-picker": "~57.0.1",
    "expo-file-system": "~57.0.1",
    "expo-font": "~57.0.1",
    "expo-glass-effect": "~57.0.1",
    "expo-haptics": "~57.0.1",
    "expo-image": "~57.0.1",
    "expo-image-manipulator": "~57.0.5",
    "expo-image-picker": "~57.0.5",
    "expo-linear-gradient": "~57.0.1",
    "expo-linking": "~57.0.3",
    "expo-location": "~57.0.5",
    "expo-network": "~57.0.1",
    "expo-router": "~57.0.7",
    "expo-secure-store": "~57.0.1",
    "expo-speech": "~57.0.1",
    "expo-speech-recognition": "^56.0.1",
    "expo-splash-screen": "~57.0.4",
    "expo-status-bar": "~57.0.1",
    "expo-symbols": "~57.0.1",
    "expo-system-ui": "~57.0.1",
    "expo-web-browser": "~57.0.1",
    "openai": "^6.48.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-native": "0.86.0",
    "react-native-element-dropdown": "^2.12.4",
    "react-native-gesture-handler": "3.1.0",
    "react-native-keyboard-controller": "1.22.2",
    "react-native-reanimated": "4.5.2",
    "react-native-safe-area-context": "5.8.0",
    "react-native-screens": "4.26.2",
    "react-native-svg": "15.15.5",
    "react-native-teleport": "^1.1.11",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.10.0",
    "reanimated-color-picker": "^5.1.2",
    "tamagui": "2.5.0",
