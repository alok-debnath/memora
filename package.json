    "@types/node": "^26.1.1",
    "@types/react": "~19.2.17",
    "@types/react-dom": "~19.2.3",
    "babel-plugin-react-compiler": "^19.0.0-beta-ebf51a3-20250411",
    "convex-test": "^0.0.54",
    "lefthook": "^2.1.10",
    "prettier": "3.9.6",
    "typescript": "~6.0.3",
