{
  "compilerOptions": {
    "strict": true,
    "noEmit": true,
    "noImplicitAny": false,
    "target": "ESNext",
    "lib": ["ES2021", "DOM"],
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "paths": {
      "convex/_generated/*": ["./_generated/*"]
    },
    "moduleResolution": "Bundler",
    "module": "ESNext"
  },
  "include": ["./**/*.ts", "./**/*.d.ts"],
  "exclude": ["./node_modules", "./**/*.js", "./**/*.js.map"]
}
